{
  "name": "chronomap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lean:dev": "node scripts/lean-dev.mjs",
    "clean": "node scripts/clean.mjs --heavy",
    "clean:heavy": "node scripts/clean.mjs --heavy",
    "clean:full": "node scripts/clean.mjs --full",
    "clean:deep": "node scripts/clean.mjs --full",
    "prepare": "husky",
    "commit": "cz",
    "commitlint": "commitlint",
    "git:guard:branch": "bash scripts/git/guard-branch.sh",
    "git:guard:no-main-push": "bash scripts/git/guard-no-main-push.sh",
    "git:guard:atomic": "bash scripts/git/guard-atomic.sh",
    "git:guard:generated": "bash scripts/git/guard-generated.sh",
    "git:guard:large-files": "bash scripts/git/guard-large-files.sh",
    "git:guard:secrets": "bash scripts/git/guard-secrets.sh",
    "git:guard:all": "pnpm git:guard:branch && pnpm git:guard:atomic && pnpm git:guard:generated && pnpm git:guard:large-files && pnpm git:guard:secrets",
    "git:commit:propose": "node scripts/git/propose-commit-message.mjs",
    "git:session:save": "bash scripts/git/session-save.sh",
    "git:session:resume": "bash scripts/git/session-resume.sh",
    "pr:notes": "bash scripts/git/generate-pr-notes.sh",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "lint-staged": "lint-staged",
    "build:ui": "pnpm build",
    "typecheck": "pnpm exec tsc --noEmit",
    "test:rust": "cd src-tauri && cargo test --lib",
    "lint:rust": "cd src-tauri && cargo clippy -- -D warnings",
    "test": "pnpm typecheck && pnpm test:rust",
    "ai:eval": "node scripts/ai/eval.mjs",
    "preflight": "node .codex/scripts/preflight.mjs",
    "verify": "bash .codex/scripts/run_verify_commands.sh",
    "perf:assert-complete": "node scripts/perf/assert-complete.mjs",
    "perf:lhci": "lhci autorun",
    "perf:lhci:prod": "LHCI_CONFIG=.lighthouserc.production.json lhci autorun",
    "release:build:dmg": "bash scripts/release/macos/build_dmg.sh",
    "release:metadata": "bash scripts/release/generate_metadata.sh",
    "release:check-secrets": "bash scripts/release/check_secrets.sh",
    "release:readiness": "node scripts/release/readiness-report.mjs",
    "release:rc:dry-run": "pnpm tauri build --bundles app && pnpm release:build:dmg && ALLOW_UNSIGNED_RELEASE=true bash scripts/release/macos/sign_and_verify.sh && ALLOW_UNSIGNED_RELEASE=true bash scripts/release/macos/notarize_and_staple.sh && pnpm release:metadata"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.2.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.55.0",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
